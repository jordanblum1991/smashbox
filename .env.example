# Copy to .env and adjust as needed.

# SQLite path (relative to repo root). Swap to a postgres URL later.
DATABASE_URL=sqlite:///./data/smashbox.db

# Default brand for v1. Multi-brand support comes later.
DEFAULT_BRAND=smashbox

# Seller-funded discount split: Outlandish share, 0.0 - 1.0.
# Smashbox share is the remainder (the two MUST add back to the total).
SELLER_FUNDED_OUTLANDISH_SHARE=0.5

# Monthly free sample allowance (units). Anything over is paid oversampling.
FREE_SAMPLE_MONTHLY_ALLOWANCE=100
