# Copy to .env and adjust as needed.

# SQLite path (relative to repo root). Swap to a postgres URL later.
DATABASE_URL=sqlite:///./data/smashbox.db

# Default brand for v1. Multi-brand support comes later.
DEFAULT_BRAND=smashbox

# Seller-funded discount split (cap-then-residual).
# Outlandish = MIN(seller-funded total, eligible_base * OUTLANDISH_CAP_PCT)
# Smashbox   = seller-funded total - Outlandish
# Eligible base = order gross subtotal before any discount.
OUTLANDISH_CAP_PCT=0.10

# Policy ceiling: total seller-funded discount should NEVER exceed this
# fraction of the eligible base (10% Outlandish + 20% Smashbox). Orders that
# breach it are still imported, but flagged for investigation.
SELLER_FUNDED_POLICY_CAP_PCT=0.30
